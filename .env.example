# Ignite Portal (Nuxt) – copy to `.env` and fill in values.

NUXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional overrides for static asset buckets when not using defaults:
# NUXT_PUBLIC_SITEMAP_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/sitemap
# NUXT_PUBLIC_DOWNLOADS_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/downloads

# Server-only: Nitro API routes (acquire/release lock, check-email, cron). Optional in local dev if those routes are unused.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Agent contacts are now read from `public.agents` in Supabase (see migrations).

# Optional: branding (favicon + logos from Supabase Storage or any public URL). Defaults are set in nuxt.config.ts.
# NUXT_PUBLIC_BRANDING_FAVICON_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public/assets/branding/favicon.png
# NUXT_PUBLIC_BRANDING_LOGO_LIGHT_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public/assets/branding/logo_light.svg
# NUXT_PUBLIC_BRANDING_LOGO_DARK_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public/assets/branding/logo_dark.svg

# Paystack: public key for inline checkout popup (pk_test_... or pk_live_...)
# NUXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxx

# Optional: viewer poll interval in ms (default 1500)
# NUXT_PUBLIC_VIEWERS_POLL_MS=1500

# Sentry (optional): enable client + server error reporting
NUXT_PUBLIC_SENTRY_DSN=https://PUBLIC_KEY@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_xxx
# SENTRY_ORG=ignite-studios
# SENTRY_PROJECT=javascript-nuxt

# Cron: secret for scheduled prune-viewers (set in Vercel Cron / scheduler)
# CRON_SECRET=your_secret_here
